# Lightning Escrow Configuration
# Copy to .env and fill in your values

# === Admin ===
# LNURL-auth pubkey (hex) — get it from the admin login page after first auth
ADMIN_PUBKEYS=
# Legacy API key (optional fallback for CLI tools)
# ADMIN_API_KEY=

# === Server ===
API_PORT=8001
FRONTEND_URL=http://localhost:5173

# LNURL base URL (must be publicly accessible for mobile wallets)
# For local development, use a tunnel:
#   cloudflared tunnel --url http://localhost:8001
LNURL_BASE_URL=http://localhost:8001

# === Fedimint ===
# Path to fedimint-cli binary (with escrow module)
FEDIMINT_CLI_PATH=/path/to/fedimint-cli
# Client data directory (joined to a federation)
FEDIMINT_DATA_DIR=/path/to/fedimint-client-data
# Or use HTTP mode (escrow-httpd daemon):
# FEDIMINT_HTTP_URL=http://127.0.0.1:5000

# === LND ===
LND_REST_URL=https://127.0.0.1:8080
LND_MACAROON_HEX=your-admin-macaroon-hex

# === Oracle Pubkeys (3 independent arbitrators for dispute resolution) ===
# Comma-separated compressed public keys (33 bytes hex each)
ORACLE_PUBKEYS=

# === Optional ===
# Skip LN payments (for testing without funded channels)
# MOCK_PAYMENTS=true
# Halt all payouts (emergency kill switch)
# PAYOUTS_HALTED=false

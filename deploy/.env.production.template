# Production environment template
# Copy to .env and fill in real values
# NEVER commit .env with real secrets!

# Admin auth: set your wallet's LNURL-auth linking pubkey (from admin login page)
ADMIN_PUBKEYS=
# Legacy API key (optional, for CLI tools like monitor.sh)
# ADMIN_API_KEY=
LNURL_BASE_URL=https://your-api-domain.example.com
FRONTEND_URL=https://your-frontend-domain.example.com
CORS_ORIGINS=https://your-frontend-domain.example.com
API_PORT=8001
DEV_SKIP_SIGNING=false

# Fedimint
FEDIMINT_CLI_PATH=/path/to/fedimint-cli
FEDIMINT_DATA_DIR=/path/to/fedimint-client-data
# Or HTTP mode:
# FEDIMINT_HTTP_URL=http://127.0.0.1:5000

# LND
LND_REST_URL=https://127.0.0.1:8080
LND_MACAROON_HEX=your-admin-macaroon-hex

# Oracle pubkeys (3 independent parties)
ORACLE_PUBKEYS=pubkey1,pubkey2,pubkey3

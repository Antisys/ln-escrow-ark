[Unit]
Description=Escrow API (FastAPI)
After=network.target

[Service]
Type=simple
User=ralf
WorkingDirectory=/home/ralf/ln-escrow
Environment=PATH=/home/ralf/ln-escrow/venv/bin:/usr/bin:/bin
EnvironmentFile=/home/ralf/ln-escrow/.env
ExecStart=/home/ralf/ln-escrow/venv/bin/uvicorn backend.api.main:app --host 0.0.0.0 --port 8001
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
